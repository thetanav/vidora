{
  "name": "vidora-monorepo",
  "private": true,
  "workspaces": [
    "web",
    "worker"
  ],
  "scripts": {
    "dev:web": "npm --prefix web run dev",
    "dev:worker": "npm --prefix worker run dev",
    "build:web": "npm --prefix web run build:node",
    "build:worker": "npm --prefix worker run build",
    "lint:web": "npm --prefix web run lint"
  }
}
